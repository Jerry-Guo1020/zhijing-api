PORT=3000
APP_NAME=zhijing-api
APP_PREFIX=api

DB_HOST=127.0.0.1
DB_PORT=3307
DB_USERNAME=root
DB_PASSWORD=123456
DB_NAME=zhijing_db
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Docker Compose MySQL host port. Uses 3307 to avoid conflicts with existing host MySQL on 3306.
MYSQL_PORT=3307

JWT_SECRET=zhijing-secret-key
JWT_EXPIRES_IN=7d
